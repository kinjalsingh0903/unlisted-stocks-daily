# Copy this file to `.env` for local testing (never commit .env)
# For production (GitHub Actions), set these as repository Secrets instead.

# --- Required: Gmail for sending the daily email ---
GMAIL_SENDER=youraddress@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop
RECIPIENT_EMAIL=youraddress@gmail.com

# --- Optional but recommended: ScraperAPI to bypass Cloudflare ---
# Without this, most sites will return 403. Get a key at https://www.scraperapi.com/
# Free tier: 1000 req/month. Paid: $29/mo for 100k.
SCRAPERAPI_KEY=
